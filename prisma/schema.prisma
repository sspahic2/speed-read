generator client {
  provider = "prisma-client"
  output   = "./generated"
  engineType = "client"
  runtime    = "nodejs"

  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String?  @unique
  emailVerified  DateTime?
  image          String?
  provider       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  accounts       Account[]
  libraryFiles   LibraryFile[]
  readerProgress ReaderProgress[]
  preferences    UserPreferences?
}

model UserPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  settings  Json     @default("{}")
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  billing Billing?
  billingWebhookEvents BillingWebhookEvent[]

  @@unique([provider, providerAccountId])
}

enum BillingPlanInterval {
  month
  year
  unknown
}

enum BillingPaymentStatus {
  failed
  success
  recovered
  refunded
}

model Billing {
  id                     String               @id @default(cuid())
  accountId              String               @unique
  lemonSubscriptionId    String               @unique
  lemonCustomerId        String?
  status                 String
  entitlementActive      Boolean              @default(false)
  productId              String?
  variantId              String?
  planInterval           BillingPlanInterval  @default(unknown)
  isPaused               Boolean              @default(false)
  pauseMode              String?
  pauseResumesAt         DateTime?
  renewsAt               DateTime?
  endsAt                 DateTime?
  trialEndsAt            DateTime?
  customerPortalUrl      String?
  updatePaymentMethodUrl String?
  updateSubscriptionUrl  String?
  lastPaymentStatus      BillingPaymentStatus?
  lastPaymentAt          DateTime?
  lastEventName          String?
  lastEventAt            DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  account       Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  webhookEvents BillingWebhookEvent[]

  @@index([status])
  @@index([entitlementActive])
  @@index([variantId])
}

model BillingWebhookEvent {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  accountId      String?
  billingId      String?
  eventName      String
  resourceType   String
  resourceId     String
  subscriptionId String?
  invoiceId      String?
  status         String?
  rawBody        String   @db.Text
  processedAt    DateTime @default(now())

  account Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  billing Billing? @relation(fields: [billingId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@index([accountId])
  @@index([eventName, resourceId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LibraryFile {
  id         String   @id @default(cuid())
  userId     String
  fileKey    String
  fileUrl    String
  fileName   String
  sourceType String   @default("upload")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  readerProgress ReaderProgress[]

  @@index([userId])
  @@index([userId, sourceType])
}

model ReaderProgress {
  id        String   @id @default(cuid())
  userId    String
  fileId    String
  blockId   String
  offset    Int
  updatedAt DateTime @updatedAt @default(now())

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  file   LibraryFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
}

model AppLog {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  level     String   @default("info")
  message   String
  metadata  Json?
  source    String?

  @@index([createdAt(sort: Desc)])
  @@index([level])
  @@index([source])
}
